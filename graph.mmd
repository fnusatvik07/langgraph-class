---
config:
  flowchart:
    curve: linear
---
graph TD;
	__start__([<p>__start__</p>]):::first
	search(search)
	writer(writer)
	critic(critic)
	save(save)
	__end__([<p>__end__</p>]):::last
	__start__ --> search;
	critic -.-> save;
	critic -.-> writer;
	search --> writer;
	writer --> critic;
	save --> __end__;
	classDef default fill:#f2f0ff,line-height:1.2
	classDef first fill-opacity:0
	classDef last fill:#bfb6fc
